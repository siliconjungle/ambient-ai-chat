{
  "name": "@social/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "social-cli": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --platform node --target node22 --out-dir dist --clean",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.4",
    "@social/shared": "*",
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
