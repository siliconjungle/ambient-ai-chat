# Root environment skeleton for local development.
# Copy the values you need into:
# - /Volumes/Repos/social-platform/apps/server/.env for the backend
# - /Volumes/Repos/social-platform/.env.local for Next.js frontend overrides
# - your shell environment for CLI-only overrides

## Server
PORT=4000
STATE_FILE=apps/server/.data/server-state.json
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_SUMMARY_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
THREAD_SUMMARY_INTERVAL=5
PROFILE_SUMMARY_INTERVAL=8
SUMMARY_RECENT_MESSAGE_LIMIT=40
AI_CONTEXT_MESSAGE_LIMIT=18
SEARCH_RESULT_LIMIT=30
COMMAND_RECOMMENDATION_LIMIT=5

## Web
NEXT_PUBLIC_CHAT_SERVER_URL=http://localhost:4000

## CLI
SOCIAL_SERVER_URL=http://localhost:4000
